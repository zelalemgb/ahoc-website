# ---------------------------------------------------------------------------
# Copy to `.env.local` and fill in. Never commit `.env.local`.
# ---------------------------------------------------------------------------

# Sanity project (create at https://www.sanity.io/manage)
NEXT_PUBLIC_SANITY_PROJECT_ID="your-project-id"
NEXT_PUBLIC_SANITY_DATASET="production"
# API version — pin to a date; bump deliberately.
NEXT_PUBLIC_SANITY_API_VERSION="2025-01-01"

# Server-only read token for draft/preview content (Sanity → API → Tokens).
# Leave blank for published-only content.
SANITY_API_READ_TOKEN=""

# Secret shared with the Sanity webhook that triggers on-demand revalidation.
SANITY_REVALIDATE_SECRET=""

# Public site URL (used for canonical URLs, sitemaps, OG tags).
NEXT_PUBLIC_SITE_URL="https://addishouseofculture.com"
