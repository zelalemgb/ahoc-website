# ---------------------------------------------------------------------------
# Copy to `.env.local` and fill in. Never commit `.env.local`.
# ---------------------------------------------------------------------------

# --- Content: Sanity CMS (create at https://www.sanity.io/manage) ---
NEXT_PUBLIC_SANITY_PROJECT_ID="your-project-id"
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2025-01-01"
# Server-only read token for draft/preview content (optional).
SANITY_API_READ_TOKEN=""
# Secret shared with the Sanity revalidation webhook.
SANITY_REVALIDATE_SECRET=""

# --- Site ---
NEXT_PUBLIC_SITE_URL="https://addishouseofculture.com"

# --- Application data: Postgres (Neon, DO Managed, Supabase…) ---
# postgres://USER:PASSWORD@HOST:PORT/DB?sslmode=require
DATABASE_URL=""

# --- Auth (Auth.js v5) ---
# Generate with: npx auth secret
AUTH_SECRET=""
# Google OAuth (https://console.cloud.google.com → Credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Payments: Chapa (https://dashboard.chapa.co → Settings → API) ---
# Use the TEST secret key while developing.
CHAPA_SECRET_KEY=""
CHAPA_PUBLIC_KEY=""

# --- Email (Resend) — for ticket confirmations (added in a later step) ---
RESEND_API_KEY=""
